PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/xpecto

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT - Use strong random strings in production (min 32 characters)
JWT_SECRET=your_jwt_secret_key_here_use_random_string_min_32_chars
SESSION_SECRET=your_session_secret_here_use_random_string_min_32_chars

# Cookie domain (only set in production)
# COOKIE_DOMAIN=.yourdomain.com

# EMAIL
ADMINS=your_email@example.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google Sheets (for pronite registrations via Google Form)
# Share your spreadsheet with the service account email (read-only is enough)
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_TAB_NAME=Form Responses 1
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
